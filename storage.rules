rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Clientes só podem ler/escrever em suas próprias pastas
    match /clients/{cpf}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.token.cpf == cpf;
    }
    
    // Admin tem acesso total a todas as pastas
    match /admin/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.token.role == "admin";
    }
    
    // Permitir que admin leia arquivos dos clientes
    match /clients/{cpf}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.token.role == "admin";
    }
  }
}
